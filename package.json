{
  "name": "receipt-cash",
  "version": "3.4.0",
  "private": true,
  "description": "A mobile-first receipt settlement PWA using Nostr and Cashu",
  "type": "module",
  "scripts": {
    "dev:http": "vite",
    "dev": "env VITE_USE_HTTPS=true vite",
    "build": "vite build && cp dist/index.html dist/404.html",
    "publish": "vite build && cp dist/index.html dist/404.html && npx nsite-cli upload dist",
    "preview": "vite preview",
    "cap:build": "CAPACITOR_BUILD=true vite build && npx cap sync",
    "cap:ios": "CAPACITOR_BUILD=true vite build && npx cap sync ios && npx cap open ios",
    "cap:android": "CAPACITOR_BUILD=true vite build && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/camera-preview": "^8.2.0",
    "@cashu/cashu-ts": "^2.5.2",
    "@getalby/sdk": "^5.1.1",
    "@scure/base": "^1.1.5",
    "@scure/bip39": "^1.2.1",
    "@vueuse/core": "^10.9.0",
    "@vueuse/rxjs": "^13.9.0",
    "applesauce-accounts": "^5.2.0",
    "applesauce-actions": "^5.1.1",
    "applesauce-content": "^5.0.0",
    "applesauce-core": "^5.2.0",
    "applesauce-loaders": "^5.1.0",
    "applesauce-relay": "^5.2.0",
    "applesauce-signers": "^5.2.0",
    "buffer": "^6.0.3",
    "canvas-confetti": "^1.9.3",
    "coco-cashu-core": "^1.1.2-rc.48",
    "coco-cashu-indexeddb": "^1.1.2-rc.48",
    "nostr-idb": "^2.4.0",
    "pinia": "^2.1.7",
    "qr-scanner": "^1.4.2",
    "qrcode.vue": "^3.6.0",
    "rxjs": "^7.8.2",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-imagetools": "^9.0.2",
    "vite-plugin-pwa": "^0.19.2"
  }
}
